{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: start",
      "type": "npm",
      "script": "start",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "frontend: test",
      "type": "npm",
      "script": "test",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "backend: run",
      "type": "shell",
      "command": "./.dotnet/dotnet",
      "args": [
        "run",
        "--project",
        "backend/FoodHelper.Api"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "backend: build",
      "type": "shell",
      "command": "./.dotnet/dotnet",
      "args": [
        "build",
        "backend/FoodHelper.slnx"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: start all",
      "dependsOn": [
        "frontend: start",
        "backend: run"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
